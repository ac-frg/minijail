      "writtenOn": "2017-04-24T22:22:38Z",
      "side": 1,
      "message": "should we use PR_CAP_AMBIENT_CLEAR_ALL before this loop ?",
      "revId": "8923285269f03a7f76b97e48c4f50d97d9bdfec2",
      "serverId": "85c56323-6fa9-3386-8a01-6480fb634889",
