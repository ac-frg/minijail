      },
      "lineNbr": 148,
      "author": {
        "id": 1067948
      },
      "writtenOn": "2015-10-21T03:35:07Z",
      "side": 1,
      "message": "That means there is an optional argument.  We could ditch this scheme and add a separate opt for enter vs new, but we\u0027d also have to add checking that the user doesn\u0027t specify both.",
      "parentUuid": "b9f26ee4_2cf82a32",
      "range": {
        "startLine": 148,
        "startChar": 33,
        "endLine": 148,
        "endChar": 35
      },
      "revId": "d71be349c2fe3b994e0a24ef6e668dfcee8db13d",
