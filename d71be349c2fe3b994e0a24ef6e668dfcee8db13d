        "patchSetId": 1
      },
      "lineNbr": 148,
      "author": {
        "id": 1076138
      },
      "writtenOn": "2015-10-21T03:43:05Z",
      "side": 1,
      "message": "Well, sometimes specifying both still makes sense! We do that for -v because we want to both enter an existing namespace, and then create a new one. That way we inherit the mounts of the namespace we\u0027re interested in, but we don\u0027t pollute it with new mounts.\n\nThis probably doesn\u0027t make sense for -e because there\u0027s no inheritance between network namespaces AFAICT.",
      "parentUuid": "99020a8c_4638e794",
      "range": {
        "startLine": 148,
        "startChar": 33,
        "endLine": 148,
        "endChar": 35
      },
